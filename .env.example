# FastAPI Backend for Myeonri (명리심리상담사)

# MySQL connection
MYSQL_HOST=mysql-service.default.svc.cluster.local
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=appdb

# CORS (프론트엔드 주소)
CORS_ORIGINS=https://myeonri.imjoe24.com,https://api.imjoe24.com,http://localhost:5173

# Groq API
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
